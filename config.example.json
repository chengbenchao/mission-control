{
  "_comment": "复制此文件为 config.json 并按需修改。所有字段均为可选。",

  "base_url": "https://your-domain.com",

  "infra_patterns": [
    "nginx",
    "caddy",
    "your-app"
  ],

  "service_urls": {
    "your-app":   "/app/",
    "your-admin": "/admin/"
  },

  "service_ports": {
    "your-app":   3000,
    "your-admin": 8080
  },

  "static_sites": [
    {
      "name": "docs",
      "url":  "/docs/",
      "desc": "项目文档",
      "dir":  "/var/www/docs"
    }
  ],

  "_webhook_comment": "Webhook 告警通过环境变量配置，不写入此文件。参见 .env.example",

  "_nginx_comment": [
    "location /manage/ {",
    "    proxy_pass http://127.0.0.1:8880/;",
    "    proxy_set_header Host $host;",
    "    proxy_set_header X-Forwarded-For $remote_addr;",
    "    proxy_set_header X-Forwarded-Prefix /manage;",
    "}"
  ]
}
