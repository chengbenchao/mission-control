# Mission Control — Environment Variables
# Copy this file and set values in your systemd service or shell.
# NEVER commit a filled-in copy of this file to version control.

# ── Required ────────────────────────────────────────────────
MC_USERNAME=admin
MC_PASSWORD=change_me_to_a_strong_password

# ── Optional ────────────────────────────────────────────────
# Auto-generated on each start if not set (sessions invalidated on restart)
MC_SESSION_SECRET=

# Server bind address and port (default: 127.0.0.1:8880)
HOST=127.0.0.1
PORT=8880

# Path to config.json (default: same directory as server.py)
CONFIG=
