# Mission Control — Environment Variables
# Copy this file to .env (for reference only) or inject directly into your
# systemd service. NEVER commit a filled-in copy to version control.

# ── Required ────────────────────────────────────────────────
MC_USERNAME=admin
MC_PASSWORD=change_me_to_a_strong_password

# ── Optional: session ────────────────────────────────────────
# Auto-generated on each start if not set (existing sessions invalidated on restart).
MC_SESSION_SECRET=

# ── Optional: network ────────────────────────────────────────
# Server bind address and port (default: 127.0.0.1:8880)
HOST=127.0.0.1
PORT=8880

# Path to config.json (default: same directory as server.py)
CONFIG=

# ── Optional: CORS ───────────────────────────────────────────
# Allowed cross-origin request origin. Leave empty to block all CORS.
# Use "*" only for local development, never in production.
# Example: MC_ALLOWED_ORIGIN=https://your-domain.com
MC_ALLOWED_ORIGIN=

# ── Optional: process filter ─────────────────────────────────
# Comma-separated process names to skip when listing orphaned port listeners.
# Processes matching these names AND listening on ports <1024 are excluded.
# Default: sshd,systemd,systemd-resolved,systemd-networkd,agetty,cron,crond
# MC_SKIP_PROCS=sshd,systemd,systemd-resolved,systemd-networkd,agetty,cron,crond

# ── Optional: health watcher interval (seconds) ──────────────
MC_WATCH_INTERVAL=60

# ── Optional: Webhook alerts ─────────────────────────────────
# Supported types: feishu | dingtalk | wecom | custom
# Leave MC_WEBHOOK_URL empty to disable alerts entirely.
MC_WEBHOOK_TYPE=feishu
MC_WEBHOOK_URL=
